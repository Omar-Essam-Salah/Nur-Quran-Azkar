# ───────────────────────────────────────────────────────────────────────────
# Third-party media that is NOT owned by this project (kept out of the repo):
#  • public/data   — generated from the quran.com API by the scripts in scripts/
#                    (run `npm run setup:content` to regenerate it locally).
#  • public/adhan  — adhan recordings owned by their reciters; add licensed
#                    files locally. The app also streams audio, so it still runs.
# ───────────────────────────────────────────────────────────────────────────
public/data/
public/adhan/
# Illuminated "Mushaf al-Wasat" page images — owned by their publisher; bundled
# locally for offline reading but not ours to redistribute in the repo.
public/mushaf/
# Adhan recording bundled into the APK as a notification sound (not ours to ship)
android/app/src/main/res/raw/*.mp3

# Release signing — NEVER commit (anyone with these can sign apps as you)
android/keystore.properties
*.keystore
*.jks

# Capacitor / Android build artifacts (the android/ source is kept)
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/app/src/main/assets/public/
*.apk
*.aab
*.keystore
*.jks

# iOS (Capacitor) — keep the project, ignore build artifacts & generated assets
ios/App/Pods/
ios/App/App/public/
ios/App/build/
ios/App/DerivedData/
ios/App/output/
ios/App/Podfile.lock
**/xcuserdata/
*.xcuserstate

# Misc
.capacitor/
*.tmp
*.bak
ios_install.log
ios_add.log
